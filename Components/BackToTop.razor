@using Microsoft.JSInterop
@inject IJSRuntime JS

<button id="backToTopBtn" class="btn btn-primary back-to-top d-none" title="Lên đầu trang">
    ↑ Lên
</button>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("jobBoard.initBackToTop");
            await JS.InvokeVoidAsync("jobBoard.initFadeIn");
            // initialize hero slider in the home page
            await JS.InvokeVoidAsync("jobBoard.initHeroSlider", ".hero-section");
        }
    }
}
