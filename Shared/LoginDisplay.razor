@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center gap-2">
            <span class="text-light fw-semibold d-flex align-items-center">
                <span class="me-2">👤</span>
                <span>@(displayName ?? authState?.User?.Identity?.Name)</span>
            </span>
            <form method="post" action="/api/auth/logout" class="m-0 p-0">
                <button type="submit" class="btn btn-outline-light btn-sm">Đăng xuất</button>
            </form>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="btn btn-outline-light btn-sm" href="/login">Đăng nhập</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private AuthenticationState? authState;
    private string? displayName;

    protected override async Task OnInitializedAsync()
    {
        // Lấy trạng thái hiện tại và đăng ký lắng nghe thay đổi
        authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        displayName = GetDisplayName(authState);
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Đảm bảo component luôn cập nhật khi có thay đổi auth state
        authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        displayName = GetDisplayName(authState);
        StateHasChanged();
    }

    private async Task Logout()
    {
        try
        {
            // Submit a form POST so the browser receives Set-Cookie and follows redirects
            await JSRuntime.InvokeVoidAsync("jobBoard.logoutForm", "/api/auth/logout");
            // Do not navigate from Blazor; the browser will follow the server redirect to '/'.
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Logout error: {ex}");
            Nav.NavigateTo("/", forceLoad: true);
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        // Khi auth state thay đổi, cập nhật tên hiển thị và re-render component
        try
        {
            var s = await task;
            authState = s;
            displayName = GetDisplayName(s);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private string? GetDisplayName(AuthenticationState? state)
    {
        var user = state?.User;
        if (user == null) return null;
        // Try common claim types for display name
        return user.Identity?.Name
            ?? user.FindFirst("DisplayName")?.Value
            ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
    }

    public void Dispose()
    {
        // Hủy đăng ký để tránh rò rỉ bộ nhớ
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
