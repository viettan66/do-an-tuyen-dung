@inherits LayoutComponentBase

<footer class="footer bg-dark text-light py-5 mt-5">
    <div class="container">
        <div class="row">
            <!-- Company Info -->
            <div class="col-md-3 mb-4">
                <h5 class="mb-3">
                    <span class="me-2">💼</span>JobFinder
                </h5>
                <p class="text-muted small">Tìm việc mơ ước dễ dàng.</p>
            </div>

            <!-- Links -->
            <div class="col-md-3 mb-4">
                <h6 class="mb-3">Liên kết</h6>
                <ul class="list-unstyled">
                    <li><a href="/" class="text-decoration-none text-light">Trang chủ</a></li>
                    <li><a href="/jobs" class="text-decoration-none text-light">Việc làm</a></li>
                    <li><a href="/login" class="text-decoration-none text-light">Đăng nhập</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-md-3 mb-4">
                <h6 class="mb-3">Liên hệ</h6>
                    <p class="text-muted small mb-2">
                        <span class="me-2">✉️</span>Email: support@jobfinder.com
                    </p>
                    <p class="text-muted small">
                        <span class="me-2">📞</span>Điện thoại: 0123 456 789
                    </p>
            </div>

            <!-- Social -->
            <div class="col-md-3 mb-4">
                <h6 class="mb-3">Theo dõi</h6>
                <div class="d-flex gap-3">
                    <a href="#" class="text-light" title="Facebook">
                        <i class="fab fa-facebook"></i>
                    </a>
                    <a href="#" class="text-light" title="LinkedIn">
                        <i class="fab fa-linkedin"></i>
                    </a>
                    <a href="#" class="text-light" title="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <hr class="border-secondary" />
        <div class="text-center text-muted small">
            <p>&copy; 2026 JobFinder. Đã đăng ký bản quyền.</p>
        </div>
    </div>
</footer>
