@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime


<div class="login-bg-gradient min-vh-100 d-flex flex-column justify-content-between">
  <div></div>
  <div class="container d-flex flex-column align-items-center justify-content-center flex-grow-1" style="min-height: 80vh;">
    <div class="glass-card p-4 p-md-5 shadow-lg" style="max-width: 420px; width: 100%;">
      <div class="text-center mb-4">
        <span style="font-size:2.2rem;">🔒</span>
        <span class="fw-bold ms-2" style="font-size:1.7rem; color:#223366; vertical-align:middle;">Đăng nhập</span>
      </div>

      <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
          <InputText class="form-control form-control-lg rounded-3 shadow-sm" @bind-Value="loginModel.Username" placeholder="Tên đăng nhập" />
        </div>
        <div class="mb-3">
          <InputText type="password" class="form-control form-control-lg rounded-3 shadow-sm" @bind-Value="loginModel.Password" placeholder="Mật khẩu" />
        </div>

        <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" type="submit" disabled="@isLoading" style="background: linear-gradient(90deg,#3576d1,#3e4fa8); border:none;">
          @if(isLoading) {
            <span class="spinner-border spinner-border-sm me-2"></span>
            <span>Đang đăng nhập...</span>
          } else {
            <span>Đăng nhập</span>
          }
        </button>

        @if (!string.IsNullOrEmpty(error))
        {
          <div class="text-center mt-3">
            <span class="text-danger fw-semibold">@error</span>
          </div>
        }
      </EditForm>
    </div>
  </div>
  <footer class="login-footer text-center py-4 mt-auto">
    <div class="mb-2" style="color:#e0e6f6; font-size:1rem;">© 2026 <span class="fw-bold">JobFinder</span>. Đã đăng ký bản quyền.</div>
    <div class="d-flex justify-content-center gap-3">
      <a href="#" class="footer-social"><i class="fab fa-facebook-f"></i></a>
      <a href="#" class="footer-social"><i class="fab fa-linkedin-in"></i></a>
      <a href="#" class="footer-social"><i class="fab fa-github"></i></a>
    </div>
  </footer>
</div>

@code {
    private LoginRequest loginModel = new LoginRequest();
    private bool isLoading = false;
    private string? error;

    private async Task HandleLogin()
    {
      try
      {
        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
          error = "Vui lòng điền đầy đủ thông tin";
          return;
        }
        isLoading = true;
        error = null;
            
            Console.WriteLine($"[DEBUG] Sending login request: username={loginModel.Username}");
            
            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(30));
            var res = await Http.PostAsJsonAsync("/api/auth/login", loginModel, cts.Token);
            
            Console.WriteLine($"[DEBUG] Response status: {res.StatusCode}");
            
            if (res.IsSuccessStatusCode)
            {
              var responseText = await res.Content.ReadAsStringAsync();
              Console.WriteLine($"[DEBUG] Login successful: {responseText}");
              // Wait for cookie to settle
              await Task.Delay(500);
              // Force full reload so Blazor picks up new auth state and header updates
              await JSRuntime.InvokeVoidAsync("eval", "window.location.reload(true)");
            }
            else if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
              error = "Tên đăng nhập hoặc mật khẩu không đúng";
            }
            else
            {
                var responseText = await res.Content.ReadAsStringAsync();
                Console.WriteLine($"[DEBUG] Login failed ({res.StatusCode}): {responseText}");
                error = $"Login failed ({res.StatusCode}). Please try again.";
            }
        }
        catch (System.Threading.Tasks.TaskCanceledException)
        {
          Console.WriteLine("[ERROR] Login request timed out");
          error = "Yêu cầu hết thời gian. Vui lòng kiểm tra kết nối.";
        }
        catch (Exception ex)
        {
          Console.WriteLine($"[ERROR] Login exception: {ex.Message}");
          error = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
