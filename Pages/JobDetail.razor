@page "/job/{Id:int}"
@using JobBoard.Models
@inject MockDataService DataService
@inject NavigationManager Nav

@if (job == null)
{
  <div class="container py-5">
    <div class="alert alert-warning text-center">Job not found.</div>
  </div>
}
else
{
  <div class="job-detail-bg py-5">
    <div class="container">
      <div class="mb-3">
        <a class="btn btn-light shadow-sm px-4 py-2 fw-semibold" href="/jobs">
          <i class="fas fa-arrow-left me-2"></i> Back to Jobs
        </a>
      </div>
      <div class="row g-4">
        <div class="col-lg-8">
          <div class="bg-white rounded-4 shadow-sm p-4 mb-4">
            <div class="d-flex align-items-center mb-2 gap-2">
              <h2 class="fw-bold mb-0">@job.Title</h2>
              <span class="badge bg-primary bg-opacity-75 ms-2" style="font-size:1rem;">@job.Type</span>
              <button class="btn btn-link ms-auto p-0" title="Save Job"><i class="far fa-bookmark fa-lg"></i></button>
            </div>
            <div class="d-flex flex-wrap gap-3 mb-3 text-muted">
              <span><i class="fas fa-building me-1"></i> @job.Department</span>
              <span><i class="fas fa-map-marker-alt me-1"></i> @job.Location</span>
              <span><i class="fas fa-money-bill-wave me-1"></i> @job.Salary</span>
              <span><i class="fas fa-calendar-alt me-1"></i> Posted @job.PostedDate.ToString("MMM dd, yyyy")</span>
            </div>
            <hr />
            <h5 class="fw-bold mb-2">Job Description</h5>
            <p>@job.Description</p>
            <h6 class="fw-bold mt-4 mb-2">Responsibilities</h6>
            <ul class="list-unstyled ms-2">
              @foreach (var resp in job.Responsibilities ?? new List<string>())
              {
                <li class="mb-1"><i class="fas fa-check-circle text-primary me-2"></i>@resp</li>
              }
            </ul>
            <h6 class="fw-bold mt-4 mb-2">Requirements</h6>
            <ul class="list-unstyled ms-2">
              @foreach (var req in job.Requirements ?? new List<string>())
              {
                <li class="mb-1"><i class="fas fa-check-circle text-primary me-2"></i>@req</li>
              }
            </ul>
            <div class="d-flex gap-3 mt-4">
              <button class="btn btn-primary btn-lg px-4 fw-bold">Apply Now</button>
              <button class="btn btn-outline-primary btn-lg px-4 fw-bold">Save Job</button>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="bg-white rounded-4 shadow-sm p-4 mb-4">
            <h5 class="fw-bold mb-3">Company</h5>
            <div class="d-flex align-items-center mb-2">
              <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:48px;height:48px;font-size:1.5rem;">JF</div>
              <div class="ms-3">
                <div class="fw-bold">JobFinder Inc.</div>
                <div class="text-muted small">Technology · 50-200 employees</div>
              </div>
            </div>
            <div class="mt-2 mb-1"><i class="fas fa-globe me-2"></i> www.jobfinder.com</div>
            <div class="mb-1"><i class="fas fa-envelope me-2"></i> hr@jobfinder.com</div>
            <div class="mb-1"><i class="fas fa-map-marker-alt me-2"></i> Ho Chi Minh City, Vietnam</div>
          </div>
          <div class="bg-white rounded-4 shadow-sm p-4 mb-4">
            <h5 class="fw-bold mb-3">Job Highlights</h5>
            <div class="d-flex flex-column gap-2">
              <div><i class="fas fa-briefcase me-2 text-primary"></i> <b>Employment Type:</b> @job.Type</div>
              <div><i class="fas fa-user-tie me-2 text-primary"></i> <b>Experience:</b> @job.Experience</div>
              <div><i class="fas fa-layer-group me-2 text-primary"></i> <b>Level:</b> @job.Level</div>
              <div><i class="fas fa-house-laptop me-2 text-primary"></i> <b>Remote:</b> @job.RemoteType</div>
              <div><i class="fas fa-calendar-day me-2 text-primary"></i> <b>Deadline:</b> @job.Deadline?.ToString("MMM dd, yyyy")</div>
            </div>
          </div>
          <div class="bg-white rounded-4 shadow-sm p-4 mb-4">
            <h5 class="fw-bold mb-3">Share Job</h5>
            <div class="d-flex gap-3">
              <a href="#" class="footer-social"><i class="fab fa-facebook-f"></i></a>
              <a href="#" class="footer-social"><i class="fab fa-linkedin-in"></i></a>
              <a href="#" class="footer-social"><i class="fab fa-twitter"></i></a>
              <a href="#" class="footer-social"><i class="fab fa-telegram-plane"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
}

@code {
  [Parameter]
  public int Id { get; set; }

  private JobPosting? job;

  protected override void OnInitialized()
  {
    job = DataService.GetJobById(Id);
    if (job == null)
    {
      // Redirect to jobs if not found
      Nav.NavigateTo("/jobs");
    }
  }
}
